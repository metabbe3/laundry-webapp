// This is your Prisma schema file for Laundry Management SaaS
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User Management
// ============================================
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash     String
  name              String
  role              Role    @default(EMPLOYEE)
  branchId          String?
  phone             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch           Branch?  @relation(fields: [id], references: [id], onDelete: SetNull)
  orders          Order[]
  assignedOrders   EmployeeAssignment[]
  paymentsReceived Payments[]

  @@index([branchId])
  @@index([role])
  @@index([email])
}

// ============================================
// Branch Management
// ============================================
model Branch {
  id          String   @id @default(uuid())
  name        String
  address    String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  orders      Order[]

  @@index([isActive])
}

// ============================================
// Customer Information (NO LOGIN REQUIRED)
// ============================================
model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  email       String?
  notes       String?
  createdAt   DateTime @default(now())

  orders       Order[]

  @@unique([phone])
}

// ============================================
// Service Types & Pricing
// ============================================
model Service {
  id              String              @id @default(uuid())
  name            String
  description     String?
  pricingType     PricingType
  basePrice       Decimal              @db.Decimal(10, 2)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())

  orderItems       OrderItem[]

  @@index([isActive])
}

// ============================================
// Custom Items (Admin-Defined)
// ============================================
model CustomItem {
  id              String              @id @default(uuid())
  name            String
  pricingType     PricingType
  price           Decimal              @db.Decimal(10, 2)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())

  orderItems       OrderItem[]

  @@index([isActive])
}

// ============================================
// Order Management
// ============================================
model Order {
  id                String          @id @default(uuid())
  orderNumber       String          @unique
  customerId        String
  branchId           String
  status            OrderStatus     @default(RECEIVED)
  totalAmount       Decimal          @db.Decimal(12, 2) @default(0)
  paidAmount        Decimal          @db.Decimal(12, 2) @default(0)
  paymentMethod     PaymentMethod?
  paymentStatus     PaymentStatus   @default(PENDING)
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  receivedAt        DateTime?
  inProgressAt      DateTime?
  readyAt           DateTime?
  deliveredAt        DateTime?

  customer          Customer         @relation(fields: [id], references: [id])
  branch            Branch           @relation(fields: [id], references: [id])
  orderItems         OrderItem[]
  statusHistory     OrderStatusHistory[]
  payments          Payments[]
  assignments        EmployeeAssignment[]

  @@unique([orderNumber])
  @@index([customerId])
  @@index([branchId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ============================================
// Order Items (Line Items)
// ============================================
model OrderItem {
  id                String      @id @default(uuid())
  orderId           String
  serviceId          String?
  customItemId       String?
  quantity           Decimal      @db.Decimal(10, 3)
  weightKg            Decimal?      @db.Decimal(10, 2)
  pricePerUnit       Decimal      @db.Decimal(10, 2)
  subtotal          Decimal      @db.Decimal(12, 2)
  notes             String?
  createdAt          DateTime   @default(now())

  order              Order              @relation(fields: [id], references: [id], onDelete: Cascade)
  service            Service?          @relation(fields: [id], references: [id])
  customItem         CustomItem?        @relation(fields: [id], references: [id])

  @@index([orderId])
}

// ============================================
// Order Status History
// ============================================
model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  status      OrderStatus
  changedBy   String
  notes       String?
  createdAt   DateTime   @default(now())

  order       Order       @relation(fields: [id], references: [id])
  user        User        @relation(fields: [id], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

// ============================================
// Payments
// ============================================
model Payments {
  id              String        @id @default(uuid())
  orderId         String
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  notes           String?
  receivedBy       String
  createdAt        DateTime      @default(now())

  order           Order       @relation(fields: [id], references: [id])
  user            User        @relation(fields: [id], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

// ============================================
// Employee Assignments
// ============================================
model EmployeeAssignment {
  id          String      @id @default(uuid())
  orderId     String
  employeeId  String
  assignedAt  DateTime   @default(now())

  order       Order       @relation(fields: [id], references: [id])
  employee    User        @relation(fields: [id], references: [id])

  @@index([orderId])
  @@index([employeeId])
}

// ============================================
// Enums
// ============================================
enum Role {
  ADMIN
  BRANCH_MANAGER
  EMPLOYEE
}

enum PricingType {
  PER_KG
  PER_ITEM
}

enum OrderStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
}

enum PaymentMethod {
  CASH
  DEPOSIT
  QRIS
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}
