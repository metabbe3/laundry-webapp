generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone         String?
  invoiceFooter String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  customers Customer[]
  services  Service[]
  orders    Order[]
  stockItems       StockItem[]
  expenseCategories ExpenseCategory[]
  expenses         Expense[]

  @@index([isActive])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole @default(EMPLOYEE)
  branchId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  notes     String?  @db.Text
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  orders Order[]

  @@unique([branchId, phone])
  @@index([branchId])
}

model Service {
  id              String         @id @default(uuid())
  name            String
  description     String?
  pricingType     PricingType
  basePrice       Decimal        @db.Decimal(10, 2)
  commissionType  CommissionType @default(NONE)
  commissionValue Decimal        @default(0) @db.Decimal(12, 2)
  isActive        Boolean        @default(true)
  branchId        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  branch     Branch      @relation(fields: [branchId], references: [id])
  orderItems OrderItem[]

  @@unique([branchId, name])
  @@index([isActive])
  @@index([branchId])
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique
  customerId    String
  status        OrderStatus   @default(RECEIVED)
  totalAmount    Decimal       @db.Decimal(12, 2) @default(0)
  discountAmount Decimal       @db.Decimal(12, 2) @default(0)
  discountType   String?
  paidAmount     Decimal       @db.Decimal(12, 2) @default(0)
  paymentStatus PaymentStatus @default(PENDING)
  notes         String?       @db.Text
  branchId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  receivedAt    DateTime?
  inProgressAt  DateTime?
  readyAt       DateTime?
  deliveredAt   DateTime?

  branch    Branch      @relation(fields: [branchId], references: [id])
  customer  Customer    @relation(fields: [customerId], references: [id])
  orderItems OrderItem[]
  payments   Payment[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([branchId])
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  serviceId    String
  quantity     Decimal  @db.Decimal(10, 3)
  weightKg     Decimal? @db.Decimal(10, 2)
  pricePerUnit Decimal  @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([orderId])
  @@index([serviceId])
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model StockItem {
  id                    String   @id @default(uuid())
  name                  String
  unit                  String
  currentQuantity       Decimal  @db.Decimal(12, 3) @default(0)
  lowStockThreshold     Decimal  @db.Decimal(12, 3) @default(0)
  purchasePricePerUnit  Decimal  @db.Decimal(12, 2) @default(0)
  isActive              Boolean  @default(true)
  branchId              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  branch    Branch           @relation(fields: [branchId], references: [id])
  movements StockMovement[]

  @@unique([branchId, name])
  @@index([isActive])
  @@index([branchId])
}

model StockMovement {
  id          String             @id @default(uuid())
  stockItemId String
  type        StockMovementType
  quantity    Decimal            @db.Decimal(12, 3)
  notes       String?
  date        DateTime           @default(now())
  createdAt   DateTime           @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([date])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  expenses Expense[]

  @@unique([branchId, name])
  @@index([branchId])
}

model Expense {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime
  categoryId  String
  branchId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch   Branch          @relation(fields: [branchId], references: [id])
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([date])
  @@index([branchId])
}

enum PricingType {
  PER_KG
  PER_ITEM
}

enum CommissionType {
  NONE
  FLAT
  PERCENTAGE
}

enum OrderStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
}

enum PaymentMethod {
  CASH
  DEPOSIT
  QRIS
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum UserRole {
  OWNER
  EMPLOYEE
}

enum StockMovementType {
  IN
  OUT
}
